#include <stdio.h>
#include <stdlib.h>

typedef struct Documento {
    int id;
    int paginas;
    int prioridade;
    struct Documento *prox;
} Documento;

typedef struct {
    Documento *inicio;
} FilaPrioridade;

void inicializarFila(FilaPrioridade *fila) {
    fila->inicio = NULL;
}

int filaVazia(FilaPrioridade *fila) {
    return fila->inicio == NULL;
}

void enqueuePrioridade(FilaPrioridade *fila, int id, int paginas, int prioridade) {
    Documento *novo = (Documento *)malloc(sizeof(Documento));
    if (novo == NULL) {
        printf("Erro de alocacao de memoria.\n");
        exit(1);
    }

    novo->id = id;
    novo->paginas = paginas;
    novo->prioridade = prioridade;
    novo->prox = NULL;

    if (fila->inicio == NULL || prioridade < fila->inicio->prioridade) {
        novo->prox = fila->inicio;
        fila->inicio = novo;
        return;
    }

