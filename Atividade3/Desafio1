Cliente *dequeue(Fila *fila) {
    if (filaVazia(fila)) {
        return NULL;
    }

    Cliente *removido = fila->inicio;
    fila->inicio = fila->inicio->prox;

    if (fila->inicio == NULL) {
        fila->fim = NULL;
    }

    return removido;
}

void liberarFila(Fila *fila) {
    Cliente *atual = fila->inicio;
    while (atual != NULL) {
        Cliente *temp = atual;
        atual = atual->prox;
        free(temp);
    }
    fila->inicio = NULL;
    fila->fim = NULL;
}

