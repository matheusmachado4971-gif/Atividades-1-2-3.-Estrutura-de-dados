#include <stdio.h>
#include <stdlib.h>

typedef struct Cliente {
    int id;
    int tempoAtendimento;
    struct Cliente *prox;
} Cliente;

typedef struct {
    Cliente *inicio;
    Cliente *fim;
} Fila;

void inicializarFila(Fila *fila) {
    fila->inicio = NULL;
    fila->fim = NULL;
}

int filaVazia(Fila *fila) {
    return fila->inicio == NULL;
}

void enqueue(Fila *fila, int id, int tempoAtendimento) {
    Cliente *novo = (Cliente *)malloc(sizeof(Cliente));
    if (novo == NULL) {
        printf("Erro de alocacao de memoria.\n");
        exit(1);
    }

    novo->id = id;
    novo->tempoAtendimento = tempoAtendimento;
    novo->prox = NULL;

    if (filaVazia(fila)) {
        fila->inicio = novo;
        fila->fim = novo;
    } else {
        fila->fim->prox = novo;
        fila->fim = novo;
    }
}

//Continuar a partir da linha 42 Ativ3Desafio1//

Cliente *dequeue(Fila *fila) {
    if (filaVazia(fila)) {
        return NULL;
    }

    Cliente *removido = fila->inicio;
    fila->inicio = fila->inicio->prox;

    if (fila->inicio == NULL) {
        fila->fim = NULL;
    }

    return removido;
}

// Continuar a partir da linha 59 Ativ3Desafio1 //

void liberarFila(Fila *fila) {
    Cliente *atual = fila->inicio;
    while (atual != NULL) {
        Cliente *temp = atual;
        atual = atual->prox;
        free(temp);
    }
    fila->inicio = NULL;
    fila->fim = NULL;
}

int main() {
    Fila fila;
    inicializarFila(&fila);

    int n;
    printf("Digite a quantidade de clientes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        int id, tempo;
        printf("\nCliente %d\n", i + 1);
        printf("Digite o ID: ");
        scanf("%d", &id);
        printf("Digite o tempo de atendimento (em minutos): ");
        scanf("%d", &tempo);

        enqueue(&fila, id, tempo);
    }

    printf("\n--- Simulacao de Atendimento ---\n");

    int tempoEspera = 0;
    while (!filaVazia(&fila)) {
        Cliente *atendido = dequeue(&fila);

        printf("Cliente ID %d atendido | Tempo de espera: %d minutos\n",
               atendido->id, tempoEspera);

        tempoEspera += atendido->tempoAtendimento;
        free(atendido);
    }

    liberarFila(&fila);

    return 0;
}
